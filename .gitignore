# Git ignore patterns for nixos-wsl repository
# Prevents accidental commits of system files, build artifacts, secrets, and machine-specific files

# === macOS ===
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# === Windows ===
# Windows thumbnail cache files
Thumbs.db
ehthumbs.db
Desktop.ini
*.lnk

# === Editor/IDE ===
# Visual Studio Code
.vscode/
.vscode-server/
*.code-workspace

# JetBrains IDEs
.idea/
*.iml
*.iws
*.ipr

# Vim/Neovim
*.swp
*.swo
*~
.*.sw?
.netrwhist

# Sublime Text
*.sublime-project
*.sublime-workspace

# Emacs
*~
\#*\#
.\#*

# === Build Artifacts ===
# Object files
*.o
*.obj
*.so
*.dll
*.dylib
*.a
*.lib

# Build directories
build/
dist/
target/
out/
bin/

# === Language-specific ===

# Node.js
node_modules/
npm-debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.npm
.eslintcache

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Ruby
Gemfile.lock
.ruby-version

# === Nix ===
# Nix build outputs and derivations
result
result-*
.dirlocal
.direnv/

# === Secrets and Credentials ===
# sops-nix age keys (NEVER commit - local only)
# .sops.yaml is intentionally NOT ignored - it contains only public keys and should be committed
secrets/*/.key
secrets/**/.key
.age/
.config/sops/age/keys.txt

# Environment variables
.env
.env.local
.env.*.local
.env.production.local

# SSH/GPG keys
id_rsa
id_dsa
id_ed25519
id_ecdsa
*.pem
*.ppk
known_hosts

# AWS credentials
.aws/credentials
.aws/config

# === Home Manager / NixOS ===
.cache/
.local/

# === Temporary Files ===
*.tmp
*.temp
*.bak
*.backup
*.old
~*

# === OS Lock Files ===
.lock
*.lock~

# === Logs ===
*.log
logs/

# === Squad: ignore runtime state (logs, inbox, sessions) ===
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
.squad/.scratch/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream
